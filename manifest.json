{
    "manifest_version": 3,
    "name": "Webcam Spoofer",
    "version": "1.0",
    "description": "Spoof webcam",
    "permissions": ["activeTab", "scripting"],
    "action": {
        "default_popup": "popup.html"
    },
    "content_scripts": [
        {
            "run_at": "document_start",
            "matches": ["<all_urls>"],
            "js": ["content.js"]
        }
    ],
    "web_accessible_resources": [
        {
            "resources": ["injected/*"],
            "matches": ["<all_urls>"]
        }
    ]
}