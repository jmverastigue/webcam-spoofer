{
    "manifest_version": 3,
    "name": "Webcam Spoofer",
    "version": "1.0",
    "description": "Spoof webcam",
    "permissions": ["activeTab", "storage"],
    "action": {
        "default_popup": "popup/popup.html"
    },
    "content_scripts": [
        {
            "run_at": "document_start",
            "matches": ["<all_urls>"],
            "js": ["/content/content.js"]
        }
    ],
    "background": {
        "service_worker": "background/background.js",
        "type": "module"
    },
    "web_accessible_resources": [
        {
            "resources": ["injected/*"],
            "matches": ["<all_urls>"]
        }
    ],
    "content_security_policy": {
        "extension_pages": "script-src 'self' https://unpkg.com/@supabase/supabase-js@2; object-src 'self'"
    }
}